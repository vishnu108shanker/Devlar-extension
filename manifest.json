{
  "manifest_version": 3,
  "name": "Devlar - by @the_evil_lord",
  "version": "2.0",
  "description": "Your AI prompt co-pilot and universal writing helper with premium UI enhancements.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_title": "Devlar Setup",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "options.html",
  "commands": {
    "optimize-prompt": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Open Devlar on selected text"
    }
  }
}